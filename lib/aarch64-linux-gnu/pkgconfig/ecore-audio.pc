prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: ecore-audio
Description: efl: ecore_audio
Version: 1.28.1
Requires: eina, eo
Requires.private: ecore, efl, sndfile, libpulse
Libs: -L${libdir} -lecore_audio
Libs.private: -pthread -lm -ldl
Cflags: -I${includedir}/ecore-audio-1
