prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: ecore-con
Description: efl: ecore_con
Version: 1.28.1
Requires: eina, eo, efl, ecore
Requires.private: eldbus, eet, emile, openssl
Libs: -L${libdir} -lecore_con
Libs.private: -lm -pthread -ldl
Cflags: -I${includedir}/ecore-con-1
