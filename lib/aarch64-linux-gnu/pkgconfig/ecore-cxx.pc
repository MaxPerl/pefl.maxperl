prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: ecore-cxx
Description: Ecore cxx bindings
Version: 1.28.1
Requires: eina-cxx, eolian-cxx, eo-cxx, efl-cxx, ecore
Requires.private: eina, eo, efl, eolian
Libs.private: -pthread -lm -lrt -ldl
Cflags: -I${includedir}/ecore-cxx-1 -I${includedir}/ecore-cxx-1
