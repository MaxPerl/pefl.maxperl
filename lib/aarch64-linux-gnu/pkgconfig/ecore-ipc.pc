prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: ecore-ipc
Description: efl: ecore_ipc
Version: 1.28.1
Requires: eina
Requires.private: ecore, eo, efl, ecore-con
Libs: -L${libdir} -lecore_ipc
Libs.private: -pthread -lm -ldl
Cflags: -I${includedir}/ecore-ipc-1
