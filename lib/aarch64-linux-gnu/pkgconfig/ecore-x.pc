prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: ecore-x
Description: efl: ecore_x
Version: 1.28.1
Requires: eina, efl
Requires.private: eo, ecore, ecore-input, x11, xcb, x11-xcb
Libs: -L${libdir} -lecore_x
Libs.private: -lm -pthread -ldl -lXcomposite -lXdamage -lXext -lXfixes -lXinerama -lXrandr -lXrender -lXtst -lXss -lXi -lXcursor
Cflags: -I${includedir}/ecore-x-1
