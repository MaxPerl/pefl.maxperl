prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: edje
Description: efl: edje
Version: 1.28.1
Requires: evas, eo, efl, lua51 < 5.2.0, lua51 >= 5.1.0
Requires.private: eina, ecore, ector, emile, eet, ecore-evas, ecore-file, ecore-input, ecore-imf, ecore-imf-evas, embryo, efreet-mime, eio, ecore-audio
Libs: -L${libdir} -ledje
Libs.private: -lm -pthread -ldl
Cflags: -I${includedir}/edje-1
