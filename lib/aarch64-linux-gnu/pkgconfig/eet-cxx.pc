prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: eet-cxx
Description: Eet cxx bindings
Version: 1.28.1
Requires: eina-cxx, eolian-cxx, eo-cxx, efl-cxx, ecore-cxx, eet
Requires.private: eina, emile, efl, eo, eolian, ecore
Libs.private: -pthread -lm -lrt -ldl
Cflags: -I${includedir}/eet-cxx-1 -I${includedir}/eet-cxx-1
