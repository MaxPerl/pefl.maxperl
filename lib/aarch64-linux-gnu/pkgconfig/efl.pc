prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: efl
Description: efl: efl
Version: 1.28.1
Requires: eo
Requires.private: eina
Libs: -L${libdir} -lefl
Libs.private: -pthread -lm -ldl
Cflags: -I${includedir}/efl-1 -I${includedir}/efl-1/interfaces
