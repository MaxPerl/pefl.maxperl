prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: eio-cxx
Description: Eio cxx bindings
Version: 1.28.1
Requires: eina-cxx, eolian-cxx, eo-cxx, efl-cxx, ecore-cxx, eet-cxx, eio
Requires.private: eina, eet, emile, efl, eo, eolian, ecore
Libs.private: -pthread -lm -lrt -ldl
Cflags: -I${includedir}/eio-cxx-1 -I${includedir}/eio-cxx-1
