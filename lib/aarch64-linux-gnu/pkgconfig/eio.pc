prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: eio
Description: efl: eio
Version: 1.28.1
Requires: eina, eet
Requires.private: ecore, eo, efl, ecore-file, emile, efreet-mime
Libs: -L${libdir} -leio
Libs.private: -lm -pthread -ldl
Cflags: -I${includedir}/eio-1
