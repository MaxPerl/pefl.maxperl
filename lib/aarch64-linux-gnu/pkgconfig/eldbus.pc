prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: eldbus
Description: efl: eldbus
Version: 1.28.1
Requires: eina, eo, efl
Requires.private: ecore, dbus-1
Libs: -L${libdir} -leldbus
Libs.private: -lm -pthread -ldl
Cflags: -I${includedir}/eldbus-1
