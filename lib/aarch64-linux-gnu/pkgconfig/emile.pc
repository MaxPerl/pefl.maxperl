prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: emile
Description: efl: emile
Version: 1.28.1
Requires: eina, efl
Requires.private: eo, libjpeg, openssl, zlib
Libs: -L${libdir} -lemile
Libs.private: -lm -pthread -ldl
Cflags: -I${includedir}/emile-1
