prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: eo-cxx
Description: Eo cxx bindings
Version: 1.28.1
Requires: eina-cxx, eolian-cxx, eo
Requires.private: eina, eolian
Libs.private: -pthread -lm -lrt -ldl
Cflags: -I${includedir}/eo-cxx-1 -I${includedir}/eo-cxx-1
