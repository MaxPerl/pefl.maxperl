prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: eolian-cxx
Description: Eolian cxx bindings
Version: 1.28.1
Requires: eina-cxx, eolian
Requires.private: eina, eo
Libs.private: -pthread -lm -lrt -ldl
Cflags: -I${includedir}/eolian-cxx-1 -I${includedir}/eolian-cxx-1
