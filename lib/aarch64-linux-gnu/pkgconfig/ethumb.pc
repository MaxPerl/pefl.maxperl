prefix=/opt/click.ubuntu.com/pefl.maxperl/current
includedir=${prefix}/include
libdir=${prefix}/lib/aarch64-linux-gnu

Name: ethumb
Description: efl: ethumb
Version: 1.28.1
Requires: eina, eo, efl
Requires.private: eet, emile, evas, ecore, ector, ecore-evas, ecore-file, ecore-imf, edje
Libs: -L${libdir} -lethumb
Libs.private: -lm -pthread -ldl
Cflags: -I${includedir}/ethumb-1
